<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quản lý Bãi Đỗ Xe UET"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1E88E5"
        android:layout_marginBottom="24dp" />

    <!-- Statistics Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thống kê bãi đỗ xe"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng chỗ:"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_total_slots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="20"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Trống:"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_available_slots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="15"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4CAF50" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Đã đỗ:"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_occupied_slots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#F44336" />
        </LinearLayout>
    </LinearLayout>

    <!-- Parking Info -->
    <TextView
        android:id="@+id/tv_parking_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Số chỗ trống: 15"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="24dp" />

    <!-- Check Availability Button -->
    <Button
        android:id="@+id/btn_check_availability"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kiểm tra chỗ trống"
        android:backgroundTint="#1E88E5"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <!-- Spacer -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="© 2024 UET Parking Management"
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center" />

</LinearLayout>
